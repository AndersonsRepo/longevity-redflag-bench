# secrets
.env

# data + outputs (large / regenerable). Large materialized data stays out; the small,
# auditable ground-truth tables + the gene blocklist (loader runtime deps) are tracked.
data/*
!data/README.md
!data/mp_mortality_terms.csv
!data/mp_mortality_classified.csv
!data/famous_gene_blocklist.csv
# canonical labeled dataset (~31M; under GitHub's 100MB limit)
!data/mgi_labeled.csv
# curated tables + benchmark selections + analysis (all small)
!data/go_hallmark_map.csv
!data/hallmark_tags.csv
!data/longevity_sample_controlled.csv
!data/longevity_sample_random.csv
!data/aging_direction.csv
# never track caches / large raw sources
data/.cache*
outputs/

# python
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/

# os/editor
.DS_Store
.vscode/
.idea/
